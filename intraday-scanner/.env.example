## Environment variables (example)
# Copy this file to `.env` and fill in your secrets. Do NOT commit `.env`.

# ScrapeGraphAI cloud API key (preferred when using ScrapeGraphAI cloud)
SCRAPEGRAPHAI_CLOUD_API_KEY=

# Alternative: put a ScrapeGraphAI cloud key here (helper fallback)
# This can also be used when the key starts with `sgai-`.
SCRAPE_LLM_API_KEY=

# LLM provider configuration (openai, ollama, gemini). Use `ollama` for local LLM.
SCRAPE_LLM_PROVIDER=ollama
SCRAPE_LLM_MODEL=

# Optional: OpenAI / Gemini keys (if using those providers)
OPENAI_API_KEY=
GEMINI_API_KEY=

# Other app settings (see config.py for defaults)
LOG_LEVEL=INFO
AUTO_REFRESH_INTERVAL_MS=60000
# AI Intraday Stock Scanner — Environment Variables
# Copy this file to .env and fill in values as needed

# ============================================================
# ScrapeGraphAI Cloud API (RECOMMENDED - no local LLM needed)
# ============================================================
# Get your API key from https://scrapegraphai.com
# Format: sgai-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
SCRAPEGRAPHAI_CLOUD_API_KEY=

# ============================================================
# Alternative: Local LLM Configuration
# Only needed if NOT using ScrapeGraphAI Cloud
# ============================================================
# Provider: ollama (default), openai, or gemini
SCRAPE_LLM_PROVIDER=ollama
# Model name (depends on provider):
#   ollama: ollama/llama3, ollama/mistral
#   openai: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
#   gemini: gemini/gemini-pro
SCRAPE_LLM_MODEL=
# API key (required for openai/gemini, not needed for ollama)
SCRAPE_LLM_API_KEY=
# Ollama base URL (only if using ollama)
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# Streamlit Configuration
# ============================================================
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
STREAMLIT_SERVER_PORT=8500
STREAMLIT_THEME_BASE=dark

# ============================================================
# Logging
# ============================================================
LOG_LEVEL=INFO

# ============================================================
# Scan Settings
# ============================================================
SCAN_RETRY_COUNT=2
SCAN_RATE_LIMIT_SECONDS=0.2
AUTO_REFRESH_INTERVAL_MS=60000
SCAN_TIMEOUT_SECONDS=45
